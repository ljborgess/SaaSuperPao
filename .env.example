# Database
DATABASE_URL=postgresql://superpao:superpao@localhost:5432/superpao
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=superpao
DATABASE_PASSWORD=superpao
DATABASE_NAME=superpao

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3001
API_URL=http://localhost:3001
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Email — desenvolvimento: usar Mailtrap (mailtrap.io)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=<mailtrap-user>
# SMTP_PASS=<mailtrap-pass>

# Email — produção: usar Resend (resend.com — 3.000 emails/mês grátis)
# 1. Criar conta em resend.com
# 2. Gerar API Key em resend.com/api-keys
# 3. Preencher abaixo:
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@superpao.com.br

# CORS
WEB_URL=http://localhost:3000
