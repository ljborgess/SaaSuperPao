{
  "name": "@superpao/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "mikro-orm migration:up --config ./mikro-orm.config.js",
    "db:migration:create": "mikro-orm migration:create --config ./mikro-orm.config.js",
    "db:seed": "mikro-orm seeder:run --config ./mikro-orm.config.js"
  },
  "dependencies": {
    "@mikro-orm/cli": "^6.4.2",
    "@mikro-orm/core": "^6.4.2",
    "@mikro-orm/migrations": "^6.4.2",
    "@mikro-orm/postgresql": "^6.4.2",
    "@mikro-orm/seeder": "^6.4.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "dotenv": "^17.4.2",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@superpao/configs": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "mikro-orm": {
    "tsConfigPath": "./tsconfig.json",
    "useTsNode": true
  }
}
